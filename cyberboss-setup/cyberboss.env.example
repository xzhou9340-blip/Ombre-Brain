# Cyberboss 本地配置 —— 最小一档(随机 checkin 开 / 微信桥开 / 定位关)
#
# 放到:  %USERPROFILE%\.cyberboss\.env
# （即 C:\Users\你的用户名\.cyberboss\.env,把本文件改名为 .env 后放进去)
#
# 两个带 __ 的值需要你自己填(见行内说明),其余照抄即可。

# --- 基本身份 ---
CYBERBOSS_USER_NAME=小雪
CYBERBOSS_USER_GENDER=female

# 你的微信 user id。作用 = 随机 checkin / 提醒 / 主动消息默认推给谁。
# 取值方式见 README-windows-setup.md 第 3 步「怎么拿到微信 user id」。
CYBERBOSS_ALLOWED_USER_IDS=__我的微信ID__

# 你想让 agent 干活的项目目录(绝对路径),例如 C:\Users\xue\my-project
# 注意:这是「你的项目」路径,不是 cyberboss 本身的克隆目录。
CYBERBOSS_WORKSPACE_ROOT=__我项目的绝对路径__

# --- runtime = Claude Code ---
CYBERBOSS_RUNTIME=claudecode

# --- 定位/whereabouts 整块关闭 ---
# false = 定位服务器不启动、不监听、不接收手机位置。
# 不要再配任何 CYBERBOSS_LOCATION_* 变量。
CYBERBOSS_ENABLE_LOCATION_SERVER=false

# 说明:随机 checkin 不用在这里配。`npm run shared:start` 启动脚本内部
# 已经写死了 `start --checkin`,所以用 shared:start 启动时 checkin 自动是开的。
# 想调整随机区间,登录后在微信里发 `/checkin <min>-<max>` 即可。
