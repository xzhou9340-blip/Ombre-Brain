# ============================================================
# Ombre-Brain 环境变量模板
# Copy to `.env` (gitignored) and fill in your own values.
# ============================================================

# ---- Compress / 脱水压缩 LLM（必需）---------------------------
# 用于 hold / grow / dream 等所有调 LLM 的工具。
# 任意 OpenAI 兼容 endpoint：DeepSeek / Gemini / Ollama / vLLM / SiliconFlow…
OMBRE_COMPRESS_API_KEY=change-me
OMBRE_COMPRESS_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OMBRE_COMPRESS_MODEL=gemini-2.5-flash-lite
OMBRE_COMPRESS_TIMEOUT_SECONDS=120

# ---- Embed / 向量化（可选，缺则语义检索关闭）-------------------
# 使用云端 OpenAI 兼容 endpoint，下面三项必填，可与 Compress 复用同一个 key/base。
OMBRE_EMBED_BACKEND=api                # 只支持 api
OMBRE_EMBED_API_KEY=change-me
OMBRE_EMBED_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OMBRE_EMBED_MODEL=gemini-embedding-001
OMBRE_EMBED_TIMEOUT_SECONDS=120

# ---- Storage / 存储 ----------------------------------------
# 桶 markdown 文件在「宿主机」上的绝对路径。docker compose 会把它挂到容器 /data。
# 示例：~/Library/Mobile Documents/iCloud~md~obsidian/Documents/<vault>/<folder>
OMBRE_HOST_VAULT_DIR=/absolute/path/to/your/vault

# 仅当你「不走 docker、直接 python/pytest」时取消注释，指向同一目录。
# compose 启动时不要设——容器内已固定为 /data。
# OMBRE_BUCKETS_DIR=/absolute/path/to/your/vault

# ---- Transport / 协议 --------------------------------------
# stdio = 本地 Claude Desktop；streamable-http = 容器/远程
OMBRE_TRANSPORT=streamable-http

# ---- Dashboard 访问密码（可选）--------------------------------
# 设置后 Dashboard 页面会要求输入密码才能访问。
# OMBRE_DASHBOARD_PASSWORD=change-me

# ---- Hooks / HTTP 钩子鉴权（可选）------------------------------
# /breath-hook 和 /dream-hook 默认不再公开；可使用 Dashboard 登录态或设置 token。
# 调用方式：?token=... 或请求头 X-Ombre-Hook-Token: ... / Authorization: Bearer ...
# OMBRE_HOOK_TOKEN=change-me
# OMBRE_HOOK_ALLOW_PUBLIC=false

# ---- AI 显示名 / AI display name（可选）-----------------------
# AI 一方的称呼，用于面向用户的文案（删除通知、信件署名等）与 letter 默认署名。
# 不设置时回退为 "AI"。例：AI_NAME=Ombre
# AI_NAME=

# ---- Reading / 共读（read-along，内嵌子进程）（全部可选）--------
# read-along 作为 node 子进程跑在本服务里（web/reading_bridge.py），
# 与 ombre 共用持久盘，全部变量留空即走默认，见 read-along/README.md。
# READING_WEB_TOKEN=            # 访问 token；不设则首启生成并持久化到盘
# READING_INTERNAL_PORT=18004   # 子进程内部端口（127.0.0.1，不对外）
# READING_DATA_DIR=             # 数据目录；默认 <buckets_dir>/read-along（持久盘）
# READING_API_BASE=             # MCP 工具的后端地址；不设则自动指向内部环回
# READING_PUSH_ENABLED / READING_PUSH_WEBHOOK 保持不设（DRY-RUN，推送只写 outbox.log）

# ---- Bark 推送（可选，bark_push 工具用）------------------------
# Bark App（https://bark.day.app）里的设备 key。未配置时 bark_push 返回提示。
# 注意：key 即推送权限，只放服务器环境变量，不要提交进仓库。
# BARK_KEY=change-me

# ---- Supabase（可选，phone_activity_query / speak 工具用）--------
# service_role key 权限很大：只放服务器环境变量，绝不进前端/客户端/日志/仓库。
# SUPABASE_URL=https://<project>.supabase.co
# SUPABASE_SERVICE_KEY=change-me

# ---- ElevenLabs 语音（可选，speak 工具用）-----------------------
# speak 工具：ElevenLabs 生成语音 → 传 Supabase Storage（voices bucket，
# 自动创建）→ Bark 推送到手机。需同时配置上面的 SUPABASE_URL /
# SUPABASE_SERVICE_KEY（存音频）；推送还需 BARK_KEY。
# ELEVENLABS_API_KEY=change-me
# ELEVENLABS_VOICE_ID=change-me

# ---- 可选 ---------------------------------------------------
# OMBRE_PORT=8000
