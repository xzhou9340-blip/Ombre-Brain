# ============================================================
# read-along 共读系统 · nginx location 片段
#
# 用法：deploy.sh 会把 __TOKEN__ 替换成随机 token 并写到
#   /etc/nginx/read-along.locations
# 你只需在已有的 443（HTTPS）server 块里加一行：
#   include /etc/nginx/read-along.locations;
# 然后 nginx -t && systemctl reload nginx
#
# 访问控制（必做，二选一或叠加）：
#   ① 随机路径 /reading-__TOKEN__/ —— deploy.sh 已做，路径本身即凭证，
#      reader.html 里的 API 常量也已同步改写；
#   ② Basic Auth —— 取消下面两处 auth_basic 注释：
#        apt install -y apache2-utils
#        htpasswd -c /etc/nginx/.htpasswd-reading 你的用户名
# 注意：Ombre MCP 的 reading_* 工具从服务器本机直连 127.0.0.1:18004，
# 不经过 nginx，因此两种方案都不影响 AI 侧。
# ============================================================

# 前端阅读器（静态文件）
location /reading-__TOKEN__/ {
    alias /var/www/reading-__TOKEN__/;
    index reader.html;

    # auth_basic "reading";
    # auth_basic_user_file /etc/nginx/.htpasswd-reading;
}

# 后端 API（反代到本机 read-along 服务）
location /reading-__TOKEN__/api/ {
    proxy_pass http://127.0.0.1:18004/api/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    client_max_body_size 50m;   # 网页端导入 epub/txt 需要（后端上限也是 50MB）

    # auth_basic "reading";
    # auth_basic_user_file /etc/nginx/.htpasswd-reading;
}
